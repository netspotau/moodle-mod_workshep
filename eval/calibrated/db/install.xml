<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/workshep/eval/calibrated/db" VERSION="20091020" COMMENT="XMLDB file for Moodle mod/workshep/eval/best"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="workshepeval_calibrated" COMMENT="Settings for the grading evaluation subplugin Calibrated against example assessments.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="workshepid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="adjustgrades" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fkuq_workshep" TYPE="foreign-unique" FIELDS="workshepid" REFTABLE="workshep" REFFIELDS="id" COMMENT="Every workshep can have only one settings record"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
